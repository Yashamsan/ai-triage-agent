# Copy this file to .env and fill in your API key
# DeepSeek (recommended — cheapest, ~$0.14/1M tokens): platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Or use Claude Haiku — uncomment and add key
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Which model to use — overrides proxy default when set
# LLM_MODEL=cheap-classifier       # routes through proxy (default)
# LLM_MODEL=deepseek/deepseek-chat  # direct, no proxy

# Langfuse observability — sign up at cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# LiteLLM Proxy — uncomment when running proxy/config.yaml locally
# LITELLM_PROXY_URL=http://localhost:4000
# LITELLM_MASTER_KEY=your_proxy_master_key_here

# Week 4: Zero Trust security
# Guard classifier model — defaults to LLM_MODEL if unset
# Set to a cheaper model to reduce guard call cost
# GUARD_MODEL=deepseek/deepseek-chat
